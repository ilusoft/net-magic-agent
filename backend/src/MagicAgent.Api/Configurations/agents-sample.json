{
  "agents": [
    {
      "id": "qualify-pricing-production",
      "name": "Qualify Pricing Productions",
      "description": "Agent to assist the qualification of productions",
      "endpoint": "{AZ_FOUNDRY_DISTRO_ENDPOINT}",
      "deployment": "gpt-5-mini",
      "apiKey": "{AZ_FOUNDRY_DISTRO_KEY}",
      "defaultParameters": {},
      "steps": [
        {
          "name": "general chat agent",
          "type": "chat",
          "parameters": {
            "systemPrompt": "You are an expert ${{ var.languages.values[iterator] }} translator agent. You should take any input text provided and translate it. The only expected output is the translated text.",
            "message": "{{var.originalInput}}"
          },
          "variableTypes": {},
          "provider": "azure-openai",
          "options": {},
          "conversation": {
            "enabled": true
          },
          "tools": [],
          "stopOnToolError": false,
          "inputSource": "usePrevious",
          "outcomes": [
            {
              "name": "agent-response",
              "nextStep": "set-out-vars",
              "condition": null,
              "endWorkflow": false,
              "order": 2
            },
            {
              "name": "check-languages-length",
              "nextStep": "increment-iterator",
              "condition": {
                "expression": "var.iterator \u003C arrayLength( var.languages.values )"
              },
              "endWorkflow": false,
              "order": 1
            }
          ],
          "isStartStep": false
        },
        {
          "name": "set-initial-vars",
          "type": "setVariables",
          "parameters": {
            "originalInput": "{{input}}",
            "languages": "${{ { \u0022values\u0022: [\u0022spanish\u0022, \u0022french\u0022, \u0022german\u0022, \u0022portuguese\u0022] } }}",
            "iterator": "0",
            "translations": "${{ [] }}"
          },
          "variableTypes": {
            "originalInput": "string",
            "languages": "json",
            "iterator": "number",
            "translations": "json"
          },
          "provider": "azure-openai",
          "options": {},
          "conversation": null,
          "tools": [],
          "stopOnToolError": false,
          "inputSource": "usePrevious",
          "outcomes": [
            {
              "name": "go-to-chat",
              "nextStep": "general chat agent",
              "condition": null,
              "endWorkflow": false,
              "order": 1
            }
          ],
          "isStartStep": true
        },
        {
          "name": "set-out-vars",
          "type": "setVariables",
          "parameters": {
            "translations": "${{ addToArray(lastOutput, var.translations) }}",
            "combinedOutput": "{{var.originalInput}} ==\u003E \n                 \n   - Spanish : \n        ${{ var.translations[0] }}\n   \n   - French :\n        ${{ var.translations[1] }}\n\n   - German :\n        ${{ var.translations[2] }}\n\n   - Portuguese :\n        ${{ var.translations[3] }}"
          },
          "variableTypes": {
            "translations": "json",
            "combinedOutput": "string"
          },
          "provider": "azure-openai",
          "options": {},
          "conversation": null,
          "tools": [],
          "stopOnToolError": false,
          "inputSource": "usePrevious",
          "outcomes": [
            {
              "name": "to-echo",
              "nextStep": "output-echo",
              "condition": null,
              "endWorkflow": false,
              "order": 1
            }
          ],
          "isStartStep": false
        },
        {
          "name": "output-echo",
          "type": "echo",
          "parameters": {
            "message": "{{var.combinedOutput}}"
          },
          "variableTypes": {},
          "provider": "azure-openai",
          "options": {},
          "conversation": null,
          "tools": [],
          "stopOnToolError": false,
          "inputSource": "usePrevious",
          "outcomes": [
            {
              "name": "finish",
              "nextStep": null,
              "condition": null,
              "endWorkflow": true,
              "order": 1
            }
          ],
          "isStartStep": false
        },
        {
          "name": "increment-iterator",
          "type": "setVariables",
          "parameters": {
            "iterator": "${{ var.iterator \u002B 1 }}",
            "translations": "${{ addToArray(lastOutput, var.translations) }}"
          },
          "variableTypes": {
            "iterator": "number",
            "translations": "json"
          },
          "provider": "azure-openai",
          "options": {},
          "conversation": null,
          "tools": [],
          "stopOnToolError": false,
          "inputSource": "usePrevious",
          "outcomes": [
            {
              "name": "continue",
              "nextStep": "general chat agent",
              "condition": {
                "expression": "true"
              },
              "endWorkflow": false,
              "order": 1
            }
          ],
          "isStartStep": false
        }
      ],
      "tools": [],
      "ViewLayout": {
