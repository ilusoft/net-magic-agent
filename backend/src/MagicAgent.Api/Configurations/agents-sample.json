{
  "agents": [
    {
      "id": "qualify-pricing-production",
      "name": "Qualify Pricing Productions",
      "description": "Agent to assist the qualification of productions",
      "endpoint": "{AZ_FOUNDRY_DISTRO_ENDPOINT}",
      "deployment": "gpt-5-mini",
      "apiKey": "{AZ_FOUNDRY_DISTRO_KEY}",
      "defaultParameters": {},
      "steps": [
        {
          "name": "general chat agent",
          "type": "chat",
          "parameters": {
            "systemPrompt": "You are an expert french translator agent. You should take any input text provided and translate it to french. The only expected output is the french translation text.",
            "message": "This is a translation : *** {{input}} ***"
          },
          "variableTypes": {},
          "provider": "azure-openai",
          "options": {},
          "conversation": {
            "enabled": true
          },
          "tools": [],
          "stopOnToolError": false,
          "inputSource": "usePrevious",
          "outcomes": [
            {
              "name": "agent-response",
              "nextStep": "set-out-vars",
              "condition": null,
              "endWorkflow": false,
              "order": 1
            }
          ],
          "isStartStep": false
        },
        {
          "name": "set-initial-vars",
          "type": "setVariables",
          "parameters": {
            "currentDate": "$preset:LocalDateTime",
            "originalInput": "{{input}}"
          },
          "variableTypes": {
            "currentDate": "dateTime"
          },
          "provider": "azure-openai",
          "options": {},
          "conversation": null,
          "tools": [],
          "stopOnToolError": false,
          "inputSource": "usePrevious",
          "outcomes": [
            {
              "name": "go-to-chat",
              "nextStep": "general chat agent",
              "condition": null,
              "endWorkflow": false,
              "order": 1
            }
          ],
          "isStartStep": true
        },
        {
          "name": "set-out-vars",
          "type": "setVariables",
          "parameters": {
            "combinedOutput": "[{{var.currentDate}}] {{var.originalInput}} ==\u003E {{lastOutput}}"
          },
          "variableTypes": {},
          "provider": "azure-openai",
          "options": {},
          "conversation": null,
          "tools": [],
          "stopOnToolError": false,
          "inputSource": "usePrevious",
          "outcomes": [
            {
              "name": "to-echo",
              "nextStep": "output-echo",
              "condition": null,
              "endWorkflow": false,
              "order": 1
            }
          ],
          "isStartStep": false
        },
        {
          "name": "output-echo",
          "type": "echo",
          "parameters": {
            "message": "{{var.combinedOutput}}"
          },
          "variableTypes": {},
          "provider": "azure-openai",
          "options": {},
          "conversation": null,
          "tools": [],
          "stopOnToolError": false,
          "inputSource": "usePrevious",
          "outcomes": [
            {
              "name": "finish",
              "nextStep": null,
              "condition": null,
              "endWorkflow": true,
              "order": 1
            }
          ],
          "isStartStep": false
        }
      ],
      "tools": [],
